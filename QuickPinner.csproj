<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyTitle>Atlas QuickPinner</AssemblyTitle>
    <AssemblyCompany>Atlas</AssemblyCompany>
    <AssemblyProduct>Atlas QuickPinner</AssemblyProduct>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <AssemblyFileVersion>1.0.0.0</AssemblyFileVersion>
    <AssemblyName>AtlasQuickPinner</AssemblyName>
    <ApplicationIcon>pin-icon.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <EmbeddedResource Include="pin-icon.ico" />
  </ItemGroup>
</Project>
